{
  "name": "electron",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.IberStudio.Windzy",
    "productName": "Windzy",
    "files": [
      "index.js",
      "preload.js",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../Backend/dist/",
        "to": "backend/",
        "filter": ["app.exe"]
      },
      {
        "from": "../Frontend/dist/",
        "to": "frontend/"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}