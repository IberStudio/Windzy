{
  "name": "electron",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "youtube-sr": "^4.3.12",
    "yt-dlp-wrap": "^2.3.12",
    "ytdl-core": "^4.11.5"
  },
  "build": {
    "appId": "com.yourapp",
    "productName": "YourAppName",
    "files": [
      "index.js",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../Backend/dist/",
        "to": "backend/",
        "filter": [
          "app.exe"
        ]
      },
      {
        "from": "../Frontend/dist/",
        "to": "frontend/"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
